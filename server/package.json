{
  "name": "delivery-rms-server",
  "version": "1.0.0",
  "description": "Delivery RMS — Express API",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "db:migrate": "knex migrate:latest --knexfile src/db/knexfile.js",
    "db:rollback": "knex migrate:rollback --knexfile src/db/knexfile.js",
    "db:seed": "knex seed:run --knexfile src/db/knexfile.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
