# Server environment variables
# Copy to .env and fill in values. Never commit .env to Git.

# ── Database ──────────────────────────────────────────────────────
# Full PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DB_URL=postgresql://postgres:yourpassword@localhost:5432/delivery_rms

# ── Server ────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────────────
# Generate strong random strings: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_random_64_byte_hex
JWT_REFRESH_SECRET=replace_with_another_random_64_byte_hex

# JWT expiry
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────
# Frontend URL (local dev)
CLIENT_URL=http://localhost:5173

# ── Google Maps (FUTURE — leave blank until Phase 5) ─────────────
# Server-side key for Distance Matrix / Directions APIs
# GOOGLE_MAPS_KEY=
